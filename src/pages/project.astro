---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqAccordion from '../components/FaqAccordion.astro';

function withBase(path: string): string {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return path === '/' ? `${base}/` : `${base}/${path.replace(/^\//, '')}`;
}

const benefits = [
  {
    title: 'Member-only events and early notice',
    description: 'Receive early notification of shopping street events, seasonal markets, and special programmes exclusive to members.',
    image: '/images/benefit-1.jpg',
  },
  {
    title: 'Community belonging and connection',
    description: 'Join a growing circle of people who share a love for local culture, crafts, and community-led initiatives.',
    image: '/images/benefit-2.jpg',
  },
  {
    title: 'Supporting local businesses',
    description: 'Your membership directly supports the shopping street\'s vitality and helps small local businesses thrive.',
    image: '/images/benefit-3.jpg',
  },
];

const faqs = [
  {
    question: 'How do I join the membership programme?',
    answer: 'First, add our official LINE account as a friend and join the open chat. Full instructions will be shared via LINE.',
  },
  {
    question: 'Can I join if I live outside the local area?',
    answer: 'Yes, you are welcome to join from anywhere. Online participation and event-only attendance are both warmly welcomed.',
  },
  {
    question: 'Are there any requirements to join?',
    answer: 'No special qualifications are needed. Anyone who wants to support Tsubaki and the local community is welcome.',
  },
  {
    question: 'Is there a minimum membership period?',
    answer: 'There is no minimum period. You may cancel at any time, though we would be grateful for your continued support.',
  },
  {
    question: 'How do I cancel my membership?',
    answer: 'To cancel, please let us know via our official LINE account and we will guide you through the process.',
  },
  {
    question: 'Where can I find more details about member benefits?',
    answer: 'Full details of member benefits are listed on the Project page. Updates are also shared regularly via LINE.',
  },
];
---

<BaseLayout title="Project — Tsubaki" description="Join the Tsubaki community programme and support local businesses.">

  <!-- HERO: Large text on cream background -->
  <section class="project-hero">
    <div class="project-hero__inner container">
      <div class="project-hero__text" data-reveal>
        <h1 class="project-hero__title" aria-label="Would you like to become part of the Tsubaki community?">
          <span>W</span><span>o</span><span>u</span><span>l</span>
          <span>d</span><span> </span><span>y</span><span>o</span>
          <span>u</span><span> </span><span>j</span><span>o</span>
          <span>i</span><span>n</span><span> </span><span>u</span>
          <span>s</span><span>?</span>
        </h1>
      </div>
      <div class="project-hero__meta" data-reveal aria-hidden="true">
        <span class="project-hero__meta-text">Tsubaki<br />Community<br />Programme</span>
      </div>
    </div>
    <div class="project-hero__brand" data-reveal>
      <img src={withBase('/images/project-hero-center.jpg')} alt="Community gathering" width="360" height="240" loading="eager" decoding="async" class="project-hero__center-image" />
    </div>
  </section>

  <!-- INTRO SECTION -->
  <section class="section">
    <div class="container project-intro" data-reveal>
      <span class="section-overline">Tsubaki Community</span>
      <div class="project-intro__body">
        <p>Tsubaki is a curated district rooted in local creativity and community. For years, it has been loved by the people who live and work here, and is home to a diverse range of shops and spaces.</p>
        <p>The Tsubaki Community Programme is an invitation to those who want to help this place flourish. Come and discover what you love here.</p>
        <p>By joining as a member, you become part of the local community network — together, we can shape the future of Tsubaki.</p>
      </div>
    </div>
  </section>

  <!-- BENEFITS SECTION -->
  <section class="section section--tinted">
    <div class="container section-shell">
      <div class="eyebrow-stack" data-reveal>
        <span class="section-overline">Member Benefits</span>
        <h2 class="section-title">Here is what<br />membership brings you</h2>
      </div>

      <div class="benefits-grid">
        {benefits.map((benefit) => (
          <article class="benefit-card" data-reveal>
            <img src={withBase(benefit.image)} alt={benefit.title} width="480" height="320" loading="lazy" decoding="async" />
            <span class="section-overline">Benefit</span>
            <h3>{benefit.title}</h3>
            <p>{benefit.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MEMBERSHIP FEE -->
  <section class="section">
    <div class="container" data-reveal>
      <div class="pricing-block">
        <div class="eyebrow-stack">
          <span class="section-overline">Membership Fee</span>
          <h2>Membership</h2>
        </div>
        <p>Membership is ¥500 per month (tax included). As a member, you can take part in community support activities and enjoy a range of exclusive benefits.</p>
      </div>
    </div>
  </section>

  <!-- HOW TO JOIN -->
  <section class="section">
    <div class="container section-shell">
      <div class="eyebrow-stack" data-reveal>
        <span class="section-overline">How to Join</span>
        <h2 class="section-title">How to Join</h2>
      </div>

      <div class="steps-grid">
        <article class="step-card" data-reveal>
          <span class="step-card__number">01</span>
          <h3>Add us on LINE</h3>
          <p>Add our official LINE account as a friend. You can register via QR code or a direct link.</p>
        </article>
        <span class="step-arrow" aria-hidden="true">→</span>
        <article class="step-card" data-reveal>
          <span class="step-card__number">02</span>
          <h3>Complete your registration</h3>
          <p>Follow the instructions in LINE to complete your membership registration.</p>
        </article>
        <span class="step-arrow" aria-hidden="true">→</span>
        <article class="step-card" data-reveal>
          <span class="step-card__number">03</span>
          <h3>Join the open chat</h3>
          <p>Once registered, you will be invited to the members-only open chat for updates and community news.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- LINE CTA -->
  <section class="section line-cta-section">
    <div class="container" data-reveal>
      <div class="line-cta">
        <h2 class="line-cta__heading">Add us on LINE</h2>
        <a href="https://line.me/" class="line-cta__btn" target="_blank" rel="noopener noreferrer">
          <span class="line-cta__icon" aria-hidden="true">LINE</span>
          Add as friend on LINE
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section class="section faq-section">
    <div class="container faq-inner section-shell">
      <div class="eyebrow-stack" data-reveal>
        <span class="section-overline">Frequently Asked Questions</span>
        <h2 class="section-title">FAQ</h2>
      </div>
      <FaqAccordion items={faqs} />
    </div>
  </section>

</BaseLayout>

<style>
  /* ====== HERO ====== */
  .project-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: var(--color-cream);
    overflow: clip;
    padding-top: var(--layout-nav-height);
  }

  .project-hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
    width: 100%;
  }

  .project-hero__text {
    padding: var(--space-2xl) 0;
  }

  .project-hero__title {
    font-family: var(--font-serif-jp);
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-ink);
    writing-mode: vertical-rl;
    letter-spacing: 0.04em;
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    max-height: 90vh;
  }

  .project-hero__title span {
    display: block;
  }

  .project-hero__meta {
    align-self: flex-start;
    padding-top: var(--space-xl);
  }

  .project-hero__meta-text {
    font-family: var(--font-sans-jp);
    font-size: var(--text-xs);
    color: var(--color-ink-light);
    letter-spacing: 0.08em;
    line-height: 1.8;
    writing-mode: vertical-rl;
    text-align: right;
  }

  .project-hero__brand {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    pointer-events: none;
  }

  .project-brand-name {
    font-family: var(--font-serif-jp);
    font-size: clamp(1rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--color-ink);
    opacity: 0.06;
    writing-mode: vertical-rl;
    line-height: 1;
    text-align: center;
  }

  .project-brand-sub {
    font-family: var(--font-display);
    font-size: clamp(0.7rem, 1.5vw, 1.1rem);
    color: var(--color-ink-light);
    opacity: 0.12;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  /* ====== INTRO ====== */
  .project-intro {
    display: grid;
    gap: 1.5rem;
    max-width: 44rem;
  }

  .project-intro__body {
    display: grid;
    gap: 1rem;
  }

  .project-intro__body p {
    font-size: var(--text-body-lg);
    line-height: var(--lh-lead);
    color: var(--color-ink-mid);
  }

  /* ====== BENEFITS ====== */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .benefit-card {
    display: grid;
    gap: 0.9rem;
    min-width: 0;
  }

  .benefit-card img {
    width: 100%;
    aspect-ratio: 1.2;
    object-fit: cover;
  }

  .benefit-card h3 {
    font-size: var(--text-h3);
    line-height: 1.3;
  }

  .benefit-card p {
    color: var(--color-ink-mid);
  }

  /* ====== PRICING ====== */
  .pricing-block {
    display: grid;
    gap: 1.5rem;
    max-width: 40rem;
  }

  .pricing-block h2 {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 400;
  }

  .pricing-block p {
    font-size: var(--text-body-lg);
    line-height: var(--lh-lead);
    color: var(--color-ink-mid);
  }

  /* ====== STEPS ====== */
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 0;
    align-items: start;
  }

  .step-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 3rem;
    font-size: 1.5rem;
    color: var(--color-gold);
  }

  .step-card {
    display: grid;
    gap: 0.9rem;
    padding: 1.5rem;
  }

  .step-card__number {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 400;
    color: var(--color-rule);
    line-height: 1;
  }

  .step-card h3 {
    font-size: var(--text-h3);
    font-family: var(--font-serif-jp);
  }

  .step-card p {
    color: var(--color-ink-mid);
  }

  /* ====== LINE CTA ====== */
  .line-cta-section {
    background: var(--color-cream-dark);
  }

  .line-cta {
    display: grid;
    gap: 2rem;
    justify-items: center;
    text-align: center;
  }

  .line-cta__heading {
    font-family: var(--font-serif-jp);
    font-size: var(--text-h2);
    color: var(--color-ink);
  }

  .line-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    background: #06C755;
    color: white;
    padding: 1rem 3rem;
    font-family: var(--font-sans-jp);
    font-size: var(--text-body);
    letter-spacing: 0.06em;
    transition: opacity var(--transition-fast);
  }

  .line-cta__btn:hover {
    opacity: 0.85;
  }

  .line-cta__icon {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  /* ====== RESPONSIVE ====== */
  @media (max-width: 960px) {
    .benefits-grid,
    .steps-grid {
      grid-template-columns: 1fr;
    }

    .step-arrow {
      transform: rotate(90deg);
      padding-top: 0;
      justify-self: center;
    }

    .project-hero__inner {
      grid-template-columns: 1fr;
    }

    .project-hero__meta {
      display: none;
    }
  }
</style>
