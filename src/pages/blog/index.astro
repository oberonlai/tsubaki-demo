---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogGrid from '@components/BlogGrid.astro';
import Pagination from '@components/Pagination.astro';
import NewsletterSignup from '@components/NewsletterSignup.astro';
import { withBase } from '@utils/base-path';

const POSTS_PER_PAGE = 9;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const totalPages = Math.max(1, Math.ceil(sortedPosts.length / POSTS_PER_PAGE));
const currentPage = 1;
const pagePosts = sortedPosts.slice(0, POSTS_PER_PAGE);
---

<BaseLayout
  title="Blog — Tsubaki"
  description="All articles, tutorials, and stories from the Tsubaki team. Topics include design, performance, GSAP animation, and Astro development."
>
  <div class="container">
    <section class="page-hero reveal" data-kanji="誌">
      <div class="page-hero__grid">
        <div>
          <p class="page-hero__eyebrow">Archive</p>
          <h1 class="page-hero__title">The journal</h1>
          <p class="page-hero__description">
            Essays on web craft, animation systems, and editorial design. Filter
            by topic below or move directly into the search page when you know
            the phrase you want.
          </p>
        </div>
        <div class="page-hero__meta">
          <div class="page-hero__stat">
            {sortedPosts.length} {sortedPosts.length === 1 ? 'post' : 'posts'}
          </div>
          <div class="page-hero__stat">Curated for calm, high-contrast reading</div>
        </div>
      </div>
    </section>

    <BlogGrid posts={pagePosts} showFilter={true} />

    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      baseUrl={withBase('/blog')}
    />

    <div style="margin-top: var(--space-16);">
      <NewsletterSignup compact={true} />
    </div>
  </div>
</BaseLayout>

<script>
  import { scrollReveal } from '@utils/animations';

  document.addEventListener('astro:page-load', async () => {
    await scrollReveal({ targets: '.reveal', stagger: 0.1 });
  });
</script>
