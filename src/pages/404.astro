---
import BaseLayout from '@layouts/BaseLayout.astro';
import { withBase } from '@utils/base-path';
---

<BaseLayout
  title="404 — Page Not Found — Tsubaki"
  description="The page you are looking for could not be found."
>
  <div class="container">
    <div class="error-page" data-kanji="余白">
      <span class="error-page__number" id="error-number" aria-hidden="true">404</span>
      <p class="section-kicker">Not in this archive</p>
      <h1 class="error-page__title">The page dissolved back into blank space.</h1>
      <p class="error-page__text">
        The address may have shifted, or the note was never bound into this issue.
        Return to the journal, or search the archive directly.
      </p>
      <div class="error-page__actions">
        <a href={withBase('/')} class="error-page__link">Back to home</a>
        <a href={withBase('/search')} class="error-page__ghost">Search archive</a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  async function init404Animation(): Promise<void> {
    const el = document.getElementById('error-number');
    if (el === null) {
      return;
    }

    const { gsap } = await import('gsap');

    // Brief bounce animation on the 404 number.
    gsap.from(el, {
      autoAlpha: 0,
      y: -40,
      duration: 0.6,
      ease: 'bounce.out',
      delay: 0.1,
    });
  }

  document.addEventListener('astro:page-load', init404Animation);
</script>
