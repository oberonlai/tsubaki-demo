---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Contact — Tsubaki" description="Contact page for Tsubaki. Feel free to reach out with any questions or inquiries.">
  <PageHero image="/images/contact-hero.jpg" alt="Street view" overline="Inquiry" title="Contact" />

  <section class="form-intro section">
    <div class="container">
      <div class="contact-intro">
        <div class="section-header" data-reveal>
          <span class="section-overline">Editorial contact form</span>
          <h2 class="section-title">Questions, press, and membership requests</h2>
        </div>
        <p class="editorial-copy" data-reveal>Every field uses quiet borders, clear labels, and readable contrast on the cream background. Categories come first so routing feels deliberate instead of generic.</p>
      </div>
    </div>
  </section>

  <section class="contact-form-section section">
    <div class="container">
      <form class="contact-form" method="POST" data-endpoint="/api/inquiries" novalidate id="contact-form">
        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label">Inquiry Category</label>
            <span class="form-required" aria-label="Required">Required</span>
          </div>
          <div class="form-radios" role="radiogroup" aria-label="Inquiry Category">
            {[
              { value: 'project', label: 'About the project' },
              { value: 'media', label: 'Media inquiries' },
              { value: 'membership', label: 'Membership (join or cancel)' },
              { value: 'other', label: 'Other inquiries' },
            ].map((opt) => (
              <label class="radio-label">
                <input type="radio" name="category" value={opt.value} class="radio-input" required />
                <span class="radio-custom" aria-hidden="true"></span>
                <span class="radio-text">{opt.label}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label" for="name">Name</label>
            <span class="form-required" aria-label="Required">Required</span>
          </div>
          <input type="text" id="name" name="name" class="form-input" placeholder="John Doe" required autocomplete="name" />
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label" for="email">Email Address</label>
            <span class="form-required" aria-label="Required">Required</span>
          </div>
          <input type="email" id="email" name="email" class="form-input" placeholder="example@email.com" required autocomplete="email" />
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label" for="phone">Phone Number</label>
            <span class="form-optional">Optional</span>
          </div>
          <input type="tel" id="phone" name="phone" class="form-input" placeholder="000-0000-0000" autocomplete="tel" />
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label" for="organization">Organization</label>
            <span class="form-optional">Optional</span>
          </div>
          <input type="text" id="organization" name="organization" class="form-input" placeholder="Company, Inc." autocomplete="organization" />
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label" for="message">Message</label>
            <span class="form-required" aria-label="Required">Required</span>
          </div>
          <textarea id="message" name="message" class="form-input form-textarea" placeholder="Please describe your inquiry" rows="6" required></textarea>
        </div>

        <div class="form-error" id="form-error" role="alert" aria-live="polite" hidden>Please review your input.</div>
        <div class="form-success" id="form-success" role="status" aria-live="polite" hidden>Your inquiry has been received. Thank you.</div>
        <button type="submit" class="form-submit">Submit</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-intro {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  .contact-form-section {
    padding-top: 0;
  }

  .contact-form {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .form-label-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .form-label,
  .form-optional {
    font-size: var(--text-xs);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--color-ink-mid);
  }

  .form-required {
    font-size: var(--text-xs);
    background-color: var(--color-gold);
    color: var(--color-white);
    padding: 2px 8px;
    letter-spacing: 0.05em;
  }

  .form-input {
    width: 100%;
    background: transparent;
    border: 1px solid var(--color-rule);
    padding: 0.9rem 1rem;
    color: var(--color-ink);
    transition: border-color var(--transition-fast);
    -webkit-appearance: none;
  }

  .form-input:focus {
    border-color: var(--color-gold);
    outline: none;
  }

  .form-input::placeholder {
    color: var(--color-ink-light);
  }

  .form-textarea {
    resize: vertical;
    min-height: 160px;
  }

  .form-radios {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem 1.5rem;
  }

  .radio-label {
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
  }

  .radio-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .radio-custom {
    width: 16px;
    height: 16px;
    border-radius: 999px;
    border: 1px solid var(--color-rule);
    position: relative;
  }

  .radio-input:checked + .radio-custom::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 999px;
    background: var(--color-gold);
  }

  .radio-text {
    color: var(--color-ink-mid);
  }

  .form-error,
  .form-success {
    padding: 0.9rem 1rem;
    color: var(--color-ink);
  }

  .form-error {
    background: rgba(184, 155, 106, 0.14);
  }

  .form-success {
    background: rgba(26, 25, 22, 0.08);
  }

  .form-submit {
    align-self: start;
    border: 0;
    background: var(--color-ink);
    color: var(--color-cream);
    padding: 0.95rem 3rem;
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .contact-intro {
      grid-template-columns: 1fr;
    }
  }
</style>
