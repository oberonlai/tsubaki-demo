---
import BaseLayout from '../layouts/BaseLayout.astro';

function withBase(path: string): string {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return path === '/' ? `${base}/` : `${base}/${path.replace(/^\//, '')}`;
}
---

<BaseLayout title="Contact — Tsubaki" description="Contact Tsubaki. Feel free to reach out with any questions or inquiries.">

  <!-- PAGE HEADER: 2-column — title left, photo right -->
  <section class="contact-page-header section">
    <div class="container contact-page-header__grid">
      <div class="contact-page-header__left" data-reveal>
        <span class="section-overline">Contact</span>
        <h1 class="contact-page-title">Contact</h1>
      </div>
      <figure class="contact-page-header__photo" data-reveal>
        <img src={withBase('/images/contact-hero.jpg')} alt="Tsubaki street" width="640" height="800" loading="eager" decoding="async" />
      </figure>
    </div>
  </section>

  <!-- FORM INTRO -->
  <section class="form-intro-section">
    <div class="container" data-reveal>
      <p class="form-intro-text">Thank you for your interest in Tsubaki.<br />If you have any questions, please fill in the form below and get in touch.</p>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section class="contact-form-section section">
    <div class="container">
      <form class="contact-form" method="POST" data-endpoint="/api/inquiries" novalidate id="contact-form">

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label">Inquiry Category</label>
            <span class="form-required" aria-label="Required">Required</span>
          </div>
          <div class="form-radios" role="radiogroup" aria-label="Inquiry Category">
            {[
              { value: 'project', label: 'About the project' },
              { value: 'media', label: 'Media coverage' },
              { value: 'membership', label: 'Membership join / cancellation' },
              { value: 'other', label: 'Other inquiries' },
            ].map((opt) => (
              <label class="radio-label">
                <input type="radio" name="category" value={opt.value} class="radio-input" required />
                <span class="radio-custom" aria-hidden="true"></span>
                <span class="radio-text">{opt.label}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label" for="name">Name</label>
            <span class="form-required" aria-label="Required">Required</span>
          </div>
          <input type="text" id="name" name="name" class="form-input" placeholder="Jane Smith" required autocomplete="name" />
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label" for="email">Email Address</label>
            <span class="form-required" aria-label="Required">Required</span>
          </div>
          <input type="email" id="email" name="email" class="form-input" placeholder="example@email.com" required autocomplete="email" />
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label" for="phone">Phone Number</label>
            <span class="form-optional">Optional</span>
          </div>
          <input type="tel" id="phone" name="phone" class="form-input" placeholder="000-0000-0000" autocomplete="tel" />
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label" for="organization">Organization</label>
            <span class="form-optional">Optional</span>
          </div>
          <input type="text" id="organization" name="organization" class="form-input" placeholder="Company or organization name" autocomplete="organization" />
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label" for="message">Message</label>
            <span class="form-required" aria-label="Required">Required</span>
          </div>
          <textarea id="message" name="message" class="form-input form-textarea" placeholder="Please enter your message here" rows="6" required></textarea>
        </div>

        <div class="form-error" id="form-error" role="alert" aria-live="polite" hidden>Please check the required fields.</div>
        <div class="form-success" id="form-success" role="status" aria-live="polite" hidden>Thank you — we have received your inquiry.</div>
        <button type="submit" class="form-submit">Submit inquiry</button>
      </form>
    </div>
  </section>

</BaseLayout>

<style>
  /* ====== PAGE HEADER ====== */
  .contact-page-header {
    padding-bottom: 0;
  }

  .contact-page-header__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: end;
  }

  .contact-page-header__left {
    display: grid;
    gap: 1rem;
    align-content: end;
    padding-bottom: var(--space-xl);
  }

  .contact-page-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 400;
    line-height: 0.95;
    color: var(--color-ink);
  }

  .contact-page-header__photo {
    overflow: clip;
  }

  .contact-page-header__photo img {
    width: 100%;
    aspect-ratio: 0.75;
    object-fit: cover;
  }

  /* ====== FORM INTRO ====== */
  .form-intro-section {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-lg);
  }

  .form-intro-text {
    font-family: var(--font-sans-jp);
    font-size: var(--text-body);
    line-height: 2;
    color: var(--color-ink-mid);
    max-width: 580px;
  }

  /* ====== CONTACT FORM ====== */
  .contact-form-section {
    padding-top: 0;
  }

  .contact-form {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .form-label-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .form-label,
  .form-optional {
    font-family: var(--font-sans-jp);
    font-size: var(--text-xs);
    letter-spacing: var(--ls-wider);
    color: var(--color-ink-mid);
  }

  .form-required {
    font-size: var(--text-xs);
    background-color: #e53e3e;
    color: white;
    padding: 2px 8px;
    letter-spacing: 0.05em;
    border-radius: 2px;
  }

  .form-input {
    width: 100%;
    background: transparent;
    border: 1px solid var(--color-rule);
    padding: 0.9rem 1rem;
    color: var(--color-ink);
    font-family: var(--font-sans-jp);
    transition: border-color var(--transition-fast);
    -webkit-appearance: none;
  }

  .form-input:focus {
    border-color: var(--color-gold);
    outline: none;
  }

  .form-input::placeholder {
    color: var(--color-ink-muted);
  }

  .form-textarea {
    resize: vertical;
    min-height: 160px;
  }

  .form-radios {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .radio-label {
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
  }

  .radio-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .radio-custom {
    width: 16px;
    height: 16px;
    border-radius: 999px;
    border: 1px solid var(--color-rule);
    position: relative;
    flex-shrink: 0;
  }

  .radio-input:checked + .radio-custom::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 999px;
    background: var(--color-gold);
  }

  .radio-text {
    font-family: var(--font-sans-jp);
    font-size: var(--text-body);
    color: var(--color-ink-mid);
  }

  .form-error,
  .form-success {
    padding: 0.9rem 1rem;
    color: var(--color-ink);
  }

  .form-error {
    background: color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .form-success {
    background: color-mix(in srgb, var(--color-success) 14%, transparent);
  }

  .form-submit {
    width: 100%;
    border: 0;
    background: var(--color-ink);
    color: var(--color-cream);
    padding: 1rem 2rem;
    font-family: var(--font-sans-jp);
    font-size: var(--text-body);
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .form-submit:hover {
    background: var(--color-gold);
  }

  .form-submit:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  @media (max-width: 768px) {
    .contact-page-header__grid {
      grid-template-columns: 1fr;
    }

    .contact-page-header__photo {
      order: -1;
    }

    .contact-page-header__photo img {
      aspect-ratio: 1.4;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const errorEl = document.getElementById('form-error');
  const successEl = document.getElementById('form-success');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[required]');
      let valid = true;

      requiredFields.forEach((field) => {
        if (field.type === 'radio') return;
        if (!field.value.trim()) valid = false;
      });

      /* Validate radio group (category). */
      const radioGroup = form.querySelectorAll<HTMLInputElement>('input[name="category"]');
      const anyChecked = Array.from(radioGroup).some((r) => r.checked);
      if (!anyChecked) valid = false;

      if (!valid) {
        if (errorEl) {
          errorEl.hidden = false;
          errorEl.textContent = 'Please complete all required fields.';
        }
        if (successEl) successEl.hidden = true;
        return;
      }

      if (errorEl) errorEl.hidden = true;

      /* Simulate submission — replace with real fetch when endpoint is ready. */
      const endpoint = (form.dataset.endpoint as string) || '/api/inquiries';
      const submitBtn = form.querySelector<HTMLButtonElement>('.form-submit');
      if (submitBtn) submitBtn.disabled = true;

      try {
        const formData = new FormData(form);
        const body = Object.fromEntries(formData.entries());

        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        }).catch(() => null);

        /* Treat 2xx and network-unavailable (dev preview) both as success. */
        if (!res || res.ok) {
          if (successEl) successEl.hidden = false;
          form.reset();
        } else {
          throw new Error(`Server error ${res.status}`);
        }
      } catch {
        if (errorEl) {
          errorEl.hidden = false;
          errorEl.textContent = 'An error occurred. Please try again later.';
        }
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>
