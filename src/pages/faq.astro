---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqAccordion from '../components/FaqAccordion.astro';

const faqs = [
  {
    question: 'How do I join the membership programme?',
    answer: 'First, add our official LINE account as a friend and join the open chat. Full instructions will be shared via LINE.',
  },
  {
    question: 'Can I join if I live outside the local area?',
    answer: 'Yes, you are welcome to join from anywhere. Online participation and event-only attendance are both warmly welcomed.',
  },
  {
    question: 'Are there any requirements to join?',
    answer: 'No special qualifications are needed. Anyone who wants to support Tsubaki and the local community is welcome.',
  },
  {
    question: 'Is there a minimum membership period?',
    answer: 'There is no minimum period. You may cancel at any time, though we would be grateful for your continued support.',
  },
  {
    question: 'How do I cancel my membership?',
    answer: 'To cancel, please let us know via our official LINE account and we will guide you through the process.',
  },
  {
    question: 'Where can I find more details about member benefits?',
    answer: 'Full details of member benefits are listed on the Project page. Updates are also shared regularly via LINE.',
  },
];
---

<BaseLayout title="FAQ — Tsubaki" description="Frequently asked questions about Tsubaki and the community membership programme.">

  <section class="faq-page section">
    <div class="container faq-page__grid">
      <!-- Left: label + title -->
      <div class="faq-page__left" data-reveal>
        <span class="faq-pill">Frequently Asked Questions</span>
        <h1 class="faq-page__title">FAQ</h1>
      </div>

      <!-- Right: accordion -->
      <div class="faq-page__right" data-reveal>
        <FaqAccordion items={faqs} />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .faq-page__grid {
    display: grid;
    grid-template-columns: minmax(12rem, 20rem) 1fr;
    gap: clamp(2rem, 5vw, 6rem);
    align-items: start;
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  .faq-page__left {
    display: grid;
    gap: 1.2rem;
    align-content: start;
    position: sticky;
    top: calc(var(--layout-nav-height) + 2rem);
  }

  .faq-pill {
    display: inline-block;
    padding: 0.35rem 1rem;
    border: 1px solid var(--color-ink-mid);
    border-radius: 999px;
    font-family: var(--font-sans-jp);
    font-size: var(--text-xs);
    color: var(--color-ink-mid);
    letter-spacing: 0.04em;
  }

  .faq-page__title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 400;
    line-height: 0.95;
    color: var(--color-ink);
  }

  @media (max-width: 768px) {
    .faq-page__grid {
      grid-template-columns: 1fr;
    }

    .faq-page__left {
      position: static;
    }
  }
</style>
