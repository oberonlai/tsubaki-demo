---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  {
    question: 'How do I join the membership?',
    answer: 'Simply click the "Subscribe" button to sign up. After registering, you will automatically receive a membership guide.',
  },
  {
    question: 'Can I join from outside the local area?',
    answer: 'Absolutely. Anyone who wishes to support our community is welcome to join, regardless of location.',
  },
  {
    question: 'Are there any membership requirements?',
    answer: 'There are no special requirements. Anyone aged 18 or above is welcome to participate.',
  },
  {
    question: 'Is there a minimum membership period?',
    answer: 'There is no minimum commitment. You are free to cancel your membership at any time.',
  },
  {
    question: 'How do I cancel my membership?',
    answer: 'You can complete the cancellation process through your account settings. Please refer to the guide sent after registration for details.',
  },
  {
    question: 'Where can I find details about the member benefits?',
    answer: 'After subscribing, we will send you a detailed guide outlining all available benefits. You can also browse a list of participating stores within your account.',
  },
];
---

<BaseLayout title="FAQ — Tsubaki" description="Frequently asked questions about the Tsubaki community and the Gather What You Love project.">

  <!-- PAGE HEADER: asymmetric 2-col layout -->
  <section class="faq-page-header section">
    <div class="container">
      <div class="faq-header-inner">
        <div class="faq-header__left">
          <span class="faq-overline">Frequently Asked Questions</span>
          <h1 class="faq-title">FAQ</h1>
        </div>

        <!-- FAQ LIST -->
        <div class="faq-list-area">
          <div class="faq-list" role="list">
            {faqs.map((faq, i) => (
              <div class="faq-item" role="listitem" data-reveal>
                <div class="h-rule"></div>
                <div class="faq-item__inner">
                  <button
                    class="faq-question"
                    type="button"
                    aria-expanded="false"
                    aria-controls={`faq-ans-${i}`}
                  >
                    <span class="faq-q-icon" aria-hidden="true">Q</span>
                    <span class="faq-q-text">{faq.question}</span>
                    <span class="faq-toggle" aria-hidden="true">＋</span>
                  </button>
                  <div class="faq-answer" id={`faq-ans-${i}`} hidden>
                    <p class="faq-answer-text">{faq.answer}</p>
                  </div>
                </div>
              </div>
            ))}
            <div class="h-rule"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ---- HEADER LAYOUT ---- */
  .faq-header-inner {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 64px;
    align-items: start;
  }

  .faq-header__left {
    padding-top: 16px;
    position: sticky;
    top: calc(var(--layout-nav-height) + 32px);
  }

  .faq-overline {
    display: inline-block;
    font-family: var(--font-sans-jp);
    font-size: var(--text-xs);
    color: var(--color-ink-mid);
    letter-spacing: var(--ls-wider);
    border: 1px solid var(--color-rule);
    border-radius: 100px;
    padding: 4px 12px;
    margin-bottom: 16px;
  }

  .faq-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, var(--text-hero));
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: 0;
    margin: 0;
    line-height: 1;
  }

  /* ---- FAQ LIST ---- */
  .faq-list-area {
    padding-top: 16px;
  }

  .faq-list {
    width: 100%;
  }

  .faq-item__inner {
    /* Inner container for question + answer. */
  }

  .faq-question {
    display: grid;
    grid-template-columns: 48px 1fr 32px;
    align-items: center;
    width: 100%;
    background: none;
    border: none;
    padding: 24px 0;
    text-align: left;
    cursor: pointer;
    gap: 16px;
  }

  .faq-q-icon {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 400;
    color: var(--color-ink-light);
    line-height: 1;
    text-align: center;
  }

  .faq-q-text {
    font-family: var(--font-sans-jp);
    font-size: var(--text-body);
    color: var(--color-ink);
    letter-spacing: var(--ls-base);
    line-height: var(--lh-body);
  }

  .faq-toggle {
    font-size: 1.25rem;
    color: var(--color-ink-mid);
    text-align: right;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .faq-question[aria-expanded="true"] .faq-toggle {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 0 24px 64px;
  }

  .faq-answer-text {
    font-family: var(--font-sans-jp);
    font-size: var(--text-body);
    color: var(--color-ink-mid);
    line-height: var(--lh-body);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .faq-header-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .faq-header__left {
      position: static;
    }

    .faq-question {
      grid-template-columns: 36px 1fr 24px;
    }

    .faq-answer {
      padding-left: 52px;
    }
  }
</style>

<script>
  function initFaq() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.faq-question');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        const answerId = btn.getAttribute('aria-controls');
        const answer = answerId ? document.getElementById(answerId) : null;

        btn.setAttribute('aria-expanded', String(!expanded));
        if (answer) {
          answer.hidden = expanded;
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initFaq);
  initFaq();
</script>
