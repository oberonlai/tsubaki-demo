---
import BaseLayout from '@layouts/BaseLayout.astro';
import NewsletterSignup from '@components/NewsletterSignup.astro';
---

<BaseLayout
  title="About — Tsubaki"
  description="Learn about the Tsubaki blog theme — our philosophy, team, and mission to make the web more beautiful and performant."
>
  <div class="container">
    <section class="page-hero reveal" data-kanji="椿">
      <div class="page-hero__grid">
        <div>
          <p class="page-hero__eyebrow">About</p>
          <h1 class="page-hero__title hero-title">A camellia-colored editorial system.</h1>
          <p class="page-hero__description">
            Tsubaki treats the blog as a designed room, not a stack of templates.
            The reading experience is guided by Ma, deliberate spacing, and typography
            with enough character to hold silence as well as language.
          </p>
        </div>
        <div class="page-hero__meta">
          <div class="page-hero__stat">Japanese print influence without museum stiffness</div>
          <div class="page-hero__stat">Astro performance with a premium editorial shell</div>
        </div>
      </div>
    </section>

    <section class="about-grid reveal">
      <article class="about-panel">
        <h2 class="about-panel__title">What it is for</h2>
        <p class="about-panel__body">
          Premium themes should feel composed before they feel feature-rich.
          Tsubaki starts with rhythm, contrast, and restraint, then adds practical
          utilities such as search, reading time, a persistent table of contents,
          and shareable article layouts.
        </p>
      </article>
      <article class="about-panel">
        <h2 class="about-panel__title">Design language</h2>
        <p class="about-panel__body">
          The palette stays warm and mineral, with camellia red reserved for
          moments of intent. Mincho headings hold ceremony; gothic body text keeps
          the reading pace contemporary. Motion behaves like a page turn, not a product demo.
        </p>
      </article>
    </section>

    <section class="section">
      <div class="page-hero reveal" data-kanji="工">
        <div class="page-hero__grid">
          <div>
            <p class="page-hero__eyebrow">Built with care</p>
            <h2 class="page-hero__title">The reading shell is as considered as the articles inside it.</h2>
          </div>
          <div class="page-hero__meta">
            <div class="page-hero__stat">Studios, solo writers, and product teams are the natural fit.</div>
          </div>
        </div>
        <ul class="about-tech-list reveal">
        {[
          { name: 'Astro', desc: 'Static site framework' },
          { name: 'GSAP', desc: 'Animation engine' },
          { name: 'MDX', desc: 'Enhanced Markdown' },
          { name: 'TypeScript', desc: 'Type safety' },
          { name: 'View Transitions', desc: 'SPA-style routing' },
          { name: 'Shippori + Zen Kaku', desc: 'Japanese type pairing' },
        ].map(({ name, desc }) => (
          <li class="about-tech-card">
            <strong>{name}</strong>
            <span>{desc}</span>
          </li>
        ))}
        </ul>
      </div>
    </section>

    <section class="about-section">
      <NewsletterSignup compact={true} />
    </section>
  </div>
</BaseLayout>

<script>
  import { splitReveal, scrollReveal } from '@utils/animations';

  document.addEventListener('astro:page-load', async () => {
    await splitReveal({ targets: '.hero-title', type: 'words', duration: 0.7, stagger: 0.06 });
    await scrollReveal({ targets: '.reveal', stagger: 0.1 });
  });
</script>
