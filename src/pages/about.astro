---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Tsubaki"
  description="Learn about the Tsubaki blog theme — our philosophy, team, and mission to make the web more beautiful and performant."
>
  <div class="container">
    <!-- About hero -->
    <section class="about-hero">
      <span class="accent-line" aria-hidden="true"></span>
      <h1 class="hero-title reveal" style="font-family: var(--font-heading); font-size: clamp(var(--text-4xl), 7vw, var(--text-6xl)); font-weight: 900; line-height: 1.1; margin-bottom: var(--space-6);">
        About Tsubaki
      </h1>
      <p class="about-section__text reveal">
        Tsubaki (椿) — the Japanese Camellia — is a symbol of understated beauty,
        perseverance, and elegance. This theme embodies those qualities: clean lines,
        purposeful space, and animations that enhance rather than distract.
      </p>
    </section>

    <!-- Mission -->
    <section class="about-section">
      <h2 class="about-section__title reveal">Our Mission</h2>
      <p class="about-section__text reveal">
        We believe great design and great performance are not in conflict. Tsubaki
        targets 95+ Lighthouse scores while delivering a reading experience that
        feels effortlessly premium. Every design decision — from the washi-paper
        cream background to the camellia-red accent — is intentional.
      </p>
    </section>

    <!-- Philosophy -->
    <section class="about-section">
      <h2 class="about-section__title reveal">Design Philosophy</h2>
      <p class="about-section__text reveal">
        Japanese editorial design has long valued the beauty of negative space
        and typographic hierarchy. Tsubaki applies these principles to the web:
        sharp corners (no border-radius), high-contrast typography with Playfair
        Display, and GSAP animations that reveal content rather than obscure it.
      </p>
      <p class="about-section__text reveal" style="margin-top: var(--space-4);">
        The result is a theme that respects the reader's attention — content-first,
        always.
      </p>
    </section>

    <!-- Technology -->
    <section class="about-section">
      <h2 class="about-section__title reveal">Built With</h2>
      <ul class="reveal" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: var(--space-4); list-style: none; margin-top: var(--space-6);">
        {[
          { name: 'Astro', desc: 'Static site framework' },
          { name: 'GSAP', desc: 'Animation engine' },
          { name: 'MDX', desc: 'Enhanced Markdown' },
          { name: 'TypeScript', desc: 'Type safety' },
          { name: 'View Transitions', desc: 'SPA-style routing' },
          { name: 'Playfair Display', desc: 'Heading typeface' },
        ].map(({ name, desc }) => (
          <li style="padding: var(--space-5); background: var(--color-surface);">
            <strong style="display: block; font-family: var(--font-heading); font-size: var(--text-lg); margin-bottom: var(--space-1);">{name}</strong>
            <span style="font-size: var(--text-sm); color: var(--color-muted);">{desc}</span>
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>

<script>
  import { splitReveal, scrollReveal } from '@utils/animations';

  document.addEventListener('astro:page-load', async () => {
    await splitReveal({ targets: '.hero-title', type: 'words', duration: 0.7, stagger: 0.06 });
    await scrollReveal({ targets: '.reveal', stagger: 0.1 });
  });
</script>
