---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionIntro from '../components/SectionIntro.astro';

function withBase(path: string): string {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return path === '/' ? `${base}/` : `${base}/${path.replace(/^\//, '')}`;
}

const stores = [
  { name: 'Yamada Coffee', category: 'Cafe', description: 'A heritage coffee house operating since the early 1930s. Serving freshly roasted, house-blend coffee.', image: '/images/store-coffee.jpg', web: '#', ig: '#' },
  { name: 'Sato Books', category: 'Books', description: 'A beloved neighborhood bookstore for over 50 years, featuring a curated section of local authors.', image: '/images/store-books.jpg', web: '#', ig: '#' },
  { name: 'Suzuki Diner', category: 'Dining', description: 'Known for set meals made with locally sourced ingredients. Expect a lunchtime queue.', image: '/images/store-diner.jpg', web: '#', ig: '#' },
  { name: 'Kotori Flowers', category: 'Florist', description: 'A flower shop that handles seasonal blooms with care. Perfect for gifts.', image: '/images/store-florist.jpg', web: '#', ig: '#' },
  { name: 'Midori Boutique', category: 'Fashion', description: 'A locally rooted fashion shop. Also offers garment alterations and tailoring.', image: '/images/store-fashion.jpg', web: '#', ig: '#' },
  { name: 'Tanaka Pharmacy', category: 'Pharmacy', description: 'A trusted neighborhood pharmacy since 1955. Friendly consultations always available.', image: '/images/store-pharmacy.jpg', web: '#', ig: '#' },
];
---

<BaseLayout title="About — Tsubaki" description="About Tsubaki. Discover the history of our community and participating stores.">
  <PageHero image="/images/about-hero.jpg" alt="Tsubaki street view" overline="About Us" title="About" serial="" summary="" />

  <section class="philosophy-section section">
    <div class="container">
      <SectionIntro overline="About the District" title="A vibrant community with a long history" lede="Tsubaki is a curated district rooted in local culture and creativity. For generations, it has stood alongside the everyday lives of local people, becoming an inseparable part of the community." detail="From long-established institutions to energetic new proprietors, our district is home to a diverse range of shops and stories. Each store has a unique character, and the warm relationships between shopkeepers and visitors make this place truly special." />

      <div class="philosophy-grid">
        <figure class="philosophy-grid__image" data-reveal>
          <img src={withBase('/images/about-main.jpg')} alt="Tsubaki storefront" width="720" height="920" loading="lazy" decoding="async" />
        </figure>
        <div class="philosophy-inner" data-reveal>
          <p class="philosophy-text">We cherish what each person loves, and we have always sought to offer things and experiences that bring genuine delight. May what we love resonate with you, adding a small but meaningful richness to your everyday life.</p>
          <p class="philosophy-text">Tsubaki is home to a rich variety of shops — from long-established names to stores run by young, passionate proprietors. The stories behind each shop and the warm connections formed with visitors are what make this place truly special.</p>
          <p class="philosophy-text">As a gathering place where people meet, conversations happen, and new connections are born, Tsubaki will continue to evolve. We are confident you will find something here that you love.</p>
          <p class="philosophy-text">Please feel free to drop by anytime. This place is filled with small joys that add colour to your daily life.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="stores-section section">
    <div class="container">
      <SectionIntro overline="Member Stores" title="Stores" lede="Tsubaki has a diverse mix of long-established and new local shops. Each store is unique and offers something special." />

      <div class="stores-grid">
        {stores.map((store) => (
          <article class="store-card" data-reveal>
            <div class="store-card__photo">
              <img src={withBase(store.image)} alt={store.name} width="400" height="300" loading="lazy" decoding="async" />
            </div>
            <div class="store-card__body">
              <span class="store-card__category">{store.category}</span>
              <h3 class="store-card__name">{store.name}</h3>
              <p class="store-card__desc">{store.description}</p>
              <div class="store-card__links">
                <a href={store.web} class="store-card__link" aria-label={`${store.name} Website`} target="_blank" rel="noopener noreferrer">Website</a>
                <a href={store.ig} class="store-card__link" aria-label={`${store.name} Instagram`} target="_blank" rel="noopener noreferrer">Instagram</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="join-section section section--cream-dark">
    <div class="container">
      <div class="join-inner" data-reveal>
        <span class="section-overline">Join the Association</span>
        <h2 class="join-heading">Join the association</h2>
        <p class="join-body">We welcome shops and individuals who wish to help revitalise the local community. Please feel free to get in touch for more details.</p>
        <p class="join-body">There are many ways to get involved — opening a new shop, participating in events, or joining the community network. We would love to welcome you.</p>
      </div>
    </div>
  </section>

  <section class="logo-section section">
    <div class="container">
      <div class="logo-inner" data-reveal>
        <span class="section-overline">About the Logo</span>
        <div class="logo-display">
          <div class="logo-mark" aria-label="Tsubaki logo">
            <div class="logo-mark__kanji-grid">
              <span>椿</span>
            </div>
            <div class="logo-mark__accent" aria-hidden="true"></div>
          </div>
          <p class="logo-desc">The Tsubaki logo mark is a design that symbolises the culture and history of the local community. The warm gold accent represents the connections within the community and the vitality of the district. The triangular mountain motif expresses the strength of the land and the spirit of its people.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .philosophy-intro,
  .stores-header {
    margin-bottom: 3rem;
  }

  .philosophy-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  .philosophy-grid__image img {
    width: 100%;
    aspect-ratio: 0.85;
    object-fit: cover;
  }

  .philosophy-text {
    font-size: var(--text-body-lg);
    line-height: var(--lh-lead);
    margin-bottom: 1rem;
  }

  .stores-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .store-card {
    display: grid;
    align-content: start;
  }

  .store-card__photo {
    margin-bottom: 16px;
    overflow: hidden;
  }

  .store-card__photo img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .store-card__category {
    display: inline-block;
    font-size: var(--text-xs);
    color: var(--color-ink-light);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .store-card__name {
    font-size: var(--text-h3);
    margin-bottom: 8px;
  }

  .store-card__desc {
    color: var(--color-ink-mid);
    margin-bottom: 1rem;
  }

  .store-card__links {
    display: flex;
    gap: 1rem;
  }

  .store-card__link {
    font-size: var(--text-sm);
    color: var(--color-gold);
  }

  .join-inner {
    max-width: 42rem;
  }

  .join-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .join-body + .join-body {
    margin-top: 0.9rem;
  }

  .logo-display {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 32px;
    align-items: center;
    margin-top: 24px;
  }

  .logo-mark {
    display: grid;
    justify-items: start;
    gap: 0.6rem;
  }

  .logo-mark__kanji-grid {
    display: flex;
    gap: 0.25em;
    font-family: var(--font-serif-jp);
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    line-height: 1.3;
  }

  .logo-mark__kanji-grid span {
    display: block;
  }

  .logo-mark__accent {
    width: 3rem;
    height: 1.4rem;
    background: var(--color-gold);
    clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }

  .logo-desc {
    color: var(--color-ink-mid);
  }

  @media (max-width: 960px) {
    .philosophy-intro,
    .philosophy-grid,
    .stores-header,
    .stores-grid,
    .logo-display {
      grid-template-columns: 1fr;
    }
  }
</style>
