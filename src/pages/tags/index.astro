---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import TagCloud from '@components/TagCloud.astro';
import { withBase } from '@utils/base-path';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Count posts per tag.
const tagCounts: Record<string, number> = {};
allPosts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  });
});

const tags = Object.entries(tagCounts)
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);

---

<BaseLayout
  title="Tags — Tsubaki"
  description="Browse all topics and tags on the Tsubaki blog."
>
  <div class="container">
    <section class="page-hero reveal" data-kanji="題">
      <div class="page-hero__grid">
        <div>
          <p class="page-hero__eyebrow">Topics</p>
          <h1 class="page-hero__title">Tags</h1>
          <p class="page-hero__description">
            Browse the archive by recurring themes, techniques, and essay types.
            The cloud leans toward the topics that shape the publication most often.
          </p>
        </div>
        <div class="page-hero__meta">
          <div class="page-hero__stat">
            {tags.length} {tags.length === 1 ? 'tag' : 'tags'}
          </div>
        </div>
      </div>
    </section>

    <div class="reveal" style="margin-bottom: var(--space-12);">
      <TagCloud tags={tags} />
    </div>

    <!-- Tags grid with post counts -->
    <div class="tags-grid reveal">
      {tags.map(({ name, count }) => (
        <a href={withBase(`/tags/${name}`)} class="tag-card">
          <span class="tag-card__name">{name}</span>
          <span class="tag-card__count">{count}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  import { scrollReveal } from '@utils/animations';

  document.addEventListener('astro:page-load', async () => {
    await scrollReveal({ targets: '.reveal', stagger: 0.08 });
  });
</script>
