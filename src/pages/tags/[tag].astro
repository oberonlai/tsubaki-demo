---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogGrid from '@components/BlogGrid.astro';
import { withBase } from '@utils/base-path';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);

  // Collect all unique tags.
  const tags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout
  title={`#${tag} — Tsubaki`}
  description={`All posts tagged with "${tag}" on the Tsubaki blog.`}
>
  <div class="container">
    <section class="page-hero reveal" data-kanji="標">
      <div class="page-hero__grid">
        <div>
          <p class="page-hero__eyebrow">Tag archive</p>
          <h1 class="page-hero__title">#{tag}</h1>
          <p class="page-hero__description">
            A focused trail through the journal. Use this tag archive to stay on one
            theme instead of reading the publication chronologically.
          </p>
        </div>
        <div class="page-hero__meta">
          <div class="page-hero__stat">
            {posts.length} {posts.length === 1 ? 'post' : 'posts'}
          </div>
          <a href={withBase('/tags')} class="hero__secondary">&larr; All tags</a>
        </div>
      </div>
    </section>

    {posts.length > 0 ? (
      <BlogGrid posts={posts} />
    ) : (
      <p style="color: var(--color-muted);">No posts found for this tag.</p>
    )}
  </div>
</BaseLayout>

<script>
  import { scrollReveal } from '@utils/animations';

  document.addEventListener('astro:page-load', async () => {
    await scrollReveal({ targets: '.reveal', stagger: 0.1 });
  });
</script>
