---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsList from '../../components/NewsList.astro';

function withBase(path: string): string {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return path === '/' ? `${base}/` : `${base}/${path.replace(/^\//, '')}`;
}

const newsItems = (await getCollection('news'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="News — Tsubaki" description="Latest news and announcements from Tsubaki.">

  <!-- PAGE HEADER: 2-column — title left, photo right -->
  <section class="news-page-header section">
    <div class="container news-page-header__grid">
      <div class="news-page-header__left" data-reveal>
        <span class="section-overline">Latest</span>
        <h1 class="news-page-title">News</h1>
      </div>
      <figure class="news-page-header__photo" data-reveal>
        <img src={withBase('/images/news-hero.jpg')} alt="Tsubaki scenery" width="640" height="800" loading="eager" decoding="async" />
      </figure>
    </div>
  </section>

  <!-- ARTICLE LIST -->
  <section class="news-list-section">
    <div class="container" data-reveal>
      <NewsList items={newsItems} />
    </div>
  </section>

</BaseLayout>

<style>
  .news-page-header {
    padding-bottom: 0;
  }

  .news-page-header__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: end;
  }

  .news-page-header__left {
    display: grid;
    gap: 1rem;
    align-content: end;
    padding-bottom: var(--space-xl);
  }

  .news-page-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 400;
    line-height: 0.95;
    color: var(--color-ink);
  }

  .news-page-header__photo {
    overflow: clip;
  }

  .news-page-header__photo img {
    width: 100%;
    aspect-ratio: 0.75;
    object-fit: cover;
  }

  .news-list-section {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .news-page-header__grid {
      grid-template-columns: 1fr;
    }

    .news-page-header__photo {
      order: -1;
    }

    .news-page-header__photo img {
      aspect-ratio: 1.4;
    }
  }
</style>
