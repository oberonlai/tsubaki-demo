---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const newsItems = await getCollection('news');
  return newsItems.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

---

<PostLayout
  title={item.data.title}
  titleEn="Neighbourhood Bulletin"
  description="Street-level updates, programme notes, and editorial notices from Tsubaki."
  date={item.data.date}
  heroImage={item.data.heroImage}
  tags={item.data.tags}
>
  <div class="article-intro">
    <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/news`} class="back-link">Back to all news</a>
  </div>
  <Content />
</PostLayout>

<style>
  .article-intro {
    margin-bottom: 1.5rem;
  }

  .back-link {
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-light);
  }
</style>
