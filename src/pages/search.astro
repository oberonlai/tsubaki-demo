---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { withBase } from '@utils/base-path';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Search — Tsubaki"
  description="Search the Tsubaki archive by title, tag, author, or excerpt."
>
  <div class="container">
    <section class="page-hero reveal" data-kanji="索">
      <div class="page-hero__grid">
        <div>
          <p class="page-hero__eyebrow">Search</p>
          <h1 class="page-hero__title">Find a note in the archive</h1>
          <p class="page-hero__description">
            Filter by title, tag, author, or excerpt. Results update instantly
            and the query stays in the URL so the same reading trail can be shared.
          </p>
        </div>
        <div class="page-hero__meta">
          <div class="page-hero__stat">{posts.length} indexed entries</div>
          <div class="page-hero__stat">Title, tags, author, and description are all searchable</div>
        </div>
      </div>
    </section>

    <div class="search-shell reveal">
      <label class="sr-only" for="search-input">Search posts</label>
      <input
        id="search-input"
        class="search-shell__input"
        type="search"
        placeholder="Search essays, tags, and topics"
        autocomplete="off"
      />
      <p class="search-shell__count" id="search-count">{posts.length} results</p>
    </div>

    <div class="search-results" id="search-results">
      {posts.map((post) => (
        <article
          class="search-result-card reveal"
          data-search-item
          data-search-title={post.data.title.toLowerCase()}
          data-search-description={post.data.description.toLowerCase()}
          data-search-tags={post.data.tags.join(' ').toLowerCase()}
          data-search-author={post.data.author.toLowerCase()}
        >
          <p class="search-result-card__tags">{post.data.tags.join(' / ')}</p>
          <a class="search-result-card__title" href={withBase(`/blog/${post.id}`)}>
            {post.data.title}
          </a>
          <p class="search-result-card__description">{post.data.description}</p>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  function initSearchPage(): void {
    const input = document.getElementById('search-input') as HTMLInputElement | null;
    const count = document.getElementById('search-count');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-search-item]'));

    if (input === null || count === null) {
      return;
    }

    const params = new URLSearchParams(window.location.search);
    input.value = params.get('q') ?? '';

    const update = (): void => {
      const query = input.value.trim().toLowerCase();
      let visible = 0;

      cards.forEach((card) => {
        const haystack = [
          card.dataset.searchTitle ?? '',
          card.dataset.searchDescription ?? '',
          card.dataset.searchTags ?? '',
          card.dataset.searchAuthor ?? '',
        ].join(' ');

        const matches = query.length === 0 || haystack.includes(query);
        card.hidden = !matches;
        if (matches) {
          visible += 1;
        }
      });

      count.textContent = `${visible} ${visible === 1 ? 'result' : 'results'}`;
      const nextParams = new URLSearchParams(window.location.search);
      if (query.length > 0) {
        nextParams.set('q', input.value);
      } else {
        nextParams.delete('q');
      }
      const next = nextParams.toString();
      window.history.replaceState({}, '', `${window.location.pathname}${next ? `?${next}` : ''}`);
    };

    input.addEventListener('input', update);
    update();
  }

  document.addEventListener('astro:page-load', initSearchPage);
</script>
