---
interface Item {
  question: string;
  answer: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="faq-stack" data-faq-root>
  {items.map((item, index) => (
    <div class="faq-stack__item">
      <div class="faq-stack__rule" aria-hidden="true"></div>
      <button
        class="faq-stack__trigger"
        type="button"
        aria-expanded="false"
        aria-controls={`faq-panel-${index}`}
        data-faq-trigger
      >
        <span class="faq-stack__mark" aria-hidden="true">Q</span>
        <span class="faq-stack__question">{item.question}</span>
        <span class="faq-stack__plus" aria-hidden="true">+</span>
      </button>
      <div class="faq-stack__panel" id={`faq-panel-${index}`} hidden data-faq-panel>
        <p>{item.answer}</p>
      </div>
    </div>
  ))}
  <div class="faq-stack__rule" aria-hidden="true"></div>
</div>

<script>
  function initFaq(root) {
    if (!root || root.dataset.faqReady === 'true') return;
    root.dataset.faqReady = 'true';
    root.querySelectorAll('[data-faq-trigger]').forEach((button) => {
      button.addEventListener('click', () => {
        const panel = button.parentElement?.querySelector('[data-faq-panel]');
        const expanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!expanded));
        panel.hidden = expanded;
      });
    });
  }

  document.querySelectorAll('[data-faq-root]').forEach(initFaq);
  document.addEventListener('astro:after-swap', () => {
    document.querySelectorAll('[data-faq-root]').forEach(initFaq);
  });
</script>

<style>
  .faq-stack__rule {
    height: 1px;
    background: var(--color-rule);
  }

  .faq-stack__trigger {
    width: 100%;
    display: grid;
    grid-template-columns: 2rem 1fr 1.5rem;
    gap: 1rem;
    align-items: center;
    padding: 1.35rem 0;
    border: 0;
    background: transparent;
    color: inherit;
    text-align: left;
  }

  .faq-stack__mark {
    color: var(--color-ink-light);
    font-family: var(--font-display);
    font-size: 1.5rem;
  }

  .faq-stack__question {
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.7;
  }

  .faq-stack__plus {
    justify-self: end;
    color: var(--color-ink-mid);
    font-size: 1.25rem;
    transition: transform var(--transition-fast);
  }

  .faq-stack__trigger[aria-expanded='true'] .faq-stack__plus {
    transform: rotate(45deg);
  }

  .faq-stack__panel {
    padding: 0 0 1.75rem 3rem;
    max-width: 68ch;
    color: var(--color-ink-mid);
  }

  @media (max-width: 720px) {
    .faq-stack__trigger {
      grid-template-columns: 1.5rem 1fr 1.25rem;
      gap: 0.75rem;
    }

    .faq-stack__panel {
      padding-left: 2.25rem;
    }
  }
</style>
