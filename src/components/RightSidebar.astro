---
/**
 * Fixed right sidebar — 36px wide.
 * Contents: social links (Instagram, Facebook) in rotated vertical text.
 * Positioned at center-right of viewport.
 */
interface SocialLink {
  label: string;
  href: string;
  icon: string;
}

interface Props {
  socialLinks?: SocialLink[];
}

const { socialLinks = [] } = Astro.props;
---

<aside class="right-sidebar" aria-label="Social links">
  <div class="right-sidebar__inner">
    {socialLinks.map((link) => (
      <a
        href={link.href}
        class="sidebar-social"
        aria-label={link.label}
        target={link.href.startsWith('http') ? '_blank' : undefined}
        rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</aside>

<style>
  .right-sidebar {
    position: fixed;
    top: 50%;
    right: 0;
    width: var(--layout-sidebar-right);
    transform: translateY(-50%);
    background-color: var(--color-cream);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .right-sidebar__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .sidebar-social {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    white-space: nowrap;
    font-family: var(--font-sans-jp);
    font-size: var(--text-sidebar);
    color: var(--color-ink-mid);
    letter-spacing: 0.05em;
    transition: color var(--transition-fast);
    text-decoration: none;
  }

  .sidebar-social:hover {
    color: var(--color-ink);
  }

  @media (max-width: 1024px) {
    .right-sidebar {
      display: none;
    }
  }
</style>
