---
/**
 * Tag cloud with gold hover fill effect.
 */
interface Props {
  tags: { name: string; count: number }[];
  activeTag?: string;
}

const { tags, activeTag } = Astro.props;

function withBase(path: string): string {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return `${base}/${path.replace(/^\//, '')}`;
}
---

<div class="tag-cloud">
  {tags.map(({ name, count }) => (
    <a
      href={withBase(`/tags/${name}`)}
      class:list={['tag-pill', name === activeTag && 'is-active']}
      aria-current={name === activeTag ? 'page' : undefined}
    >
      {name}
      <span class="tag-pill__count">({count})</span>
    </a>
  ))}
</div>

<style>
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: 4px 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--text-caption);
    letter-spacing: var(--ls-tight);
    color: var(--color-text-primary);
    background-color: transparent;
    text-decoration: none;
    transition:
      background-color var(--transition-base),
      color var(--transition-base),
      border-color var(--transition-base);
  }

  .tag-pill:hover,
  .tag-pill.is-active {
    background-color: var(--color-accent);
    color: var(--color-bg-surface);
    border-color: var(--color-accent);
  }

  .tag-pill__count {
    color: inherit;
    opacity: 0.7;
  }
</style>
