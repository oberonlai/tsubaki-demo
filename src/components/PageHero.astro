---
interface Props {
  image: string;
  overline: string;
  title: string;
  alt: string;
  align?: 'left' | 'center';
  compact?: boolean;
}

const {
  image,
  overline,
  title,
  alt,
  align = 'left',
  compact = false,
} = Astro.props;

function withBase(path: string): string {
  if (/^(?:[a-z]+:)?\/\//i.test(path)) return path;
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return path === '/' ? `${base}/` : `${base}/${path.replace(/^\//, '')}`;
}
---

<section class:list={['page-hero', compact && 'page-hero--compact']}>
  <img class="page-hero__media" src={withBase(image)} alt={alt} width="1600" height="900" loading="eager" decoding="async" />
  <div class="page-hero__veil" aria-hidden="true"></div>
  <div class:list={['page-hero__content', `page-hero__content--${align}`]}>
    <span class="page-hero__overline">{overline}</span>
    <h1 class="page-hero__title">{title}</h1>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    min-height: 24rem;
    overflow: clip;
    isolation: isolate;
  }

  .page-hero--compact {
    min-height: 21rem;
  }

  .page-hero__media,
  .page-hero__veil {
    position: absolute;
    inset: 0;
  }

  .page-hero__media {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .page-hero__veil {
    background:
      linear-gradient(110deg, rgba(243, 240, 234, 0.82) 0%, rgba(243, 240, 234, 0.18) 44%, rgba(26, 25, 22, 0.28) 100%);
  }

  .page-hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.5rem;
    min-height: inherit;
    width: min(100%, var(--layout-max-width));
    margin-inline: auto;
    padding: clamp(5rem, 8vw, 7rem) clamp(1.5rem, 6vw, 5rem) clamp(2.25rem, 4vw, 3.5rem);
  }

  .page-hero__content--center {
    place-content: center;
    text-align: center;
  }

  .page-hero__content--left {
    place-content: end start;
  }

  .page-hero__overline {
    font-size: var(--text-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--color-ink-light);
  }

  .page-hero__title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 8vw, 5.5rem);
    line-height: 0.9;
    font-weight: 400;
    letter-spacing: 0;
    max-width: 10ch;
  }

  @media (max-width: 720px) {
    .page-hero,
    .page-hero--compact {
      min-height: 17rem;
    }

    .page-hero__veil {
      background: linear-gradient(180deg, rgba(243, 240, 234, 0.7) 0%, rgba(26, 25, 22, 0.38) 100%);
    }
  }
</style>
