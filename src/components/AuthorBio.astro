---
interface Props {
  author: string;
}

const { author } = Astro.props;

// Generate initials from author name for the avatar placeholder.
const initials = author
  .split(' ')
  .map((word) => word[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();

const authorBios: Record<string, string> = {
  'Codotx Team':
    'We build premium Astro themes and templates that combine beautiful design with excellent performance. Follow us for tutorials, design tips, and open-source work.',
};

const bio = authorBios[author] ?? `Written by ${author}.`;
---

<aside class="author-bio reveal" aria-label="About the author">
  <div class="author-bio__avatar" aria-hidden="true">{initials}</div>
  <div class="author-bio__content">
    <p class="author-bio__name">{author}</p>
    <p class="author-bio__description">{bio}</p>
  </div>
</aside>
