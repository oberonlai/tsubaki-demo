---
import { withBase } from '@utils/base-path';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="section-kicker">Closing notes</span>
      <p class="footer__title">Tsubaki</p>
      <p class="footer__text">
        A premium Astro journal theme composed like a print folio: deliberate pacing,
        asymmetry, and motion that feels ceremonial instead of synthetic.
      </p>
    </div>
    <nav class="footer__links" aria-label="Footer navigation">
      <a href={withBase('/rss.xml')} class="footer__link">RSS</a>
      <a href={withBase('/sitemap-index.xml')} class="footer__link">Sitemap</a>
      <a href={withBase('/about')} class="footer__link">About</a>
      <a href="https://astro.build" class="footer__link" target="_blank" rel="noopener noreferrer">Built on Astro</a>
    </nav>
  </div>
</footer>
