---
interface NavLink {
  label: string;
  href: string;
}

interface SocialLink {
  label: string;
  href: string;
  icon: string;
}

interface Props {
  siteName?: string;
  navLinks?: NavLink[];
  socialLinks?: SocialLink[];
  copyrightYear?: number;
}

const {
  siteName = 'Tsubaki',
  navLinks = [],
  socialLinks = [],
  copyrightYear = new Date().getFullYear(),
} = Astro.props;

function withBase(path: string): string {
  if (/^(?:[a-z]+:)?\/\//i.test(path)) return path;
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return path === '/' ? `${base}/` : `${base}/${path.replace(/^\//, '')}`;
}
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">
    <!-- Large photo left -->
    <div class="footer-photo">
      <img src={withBase('/images/store-coffee.jpg')} alt="Kencho-dori cafe scene" width="640" height="560" loading="lazy" decoding="async" />
    </div>

    <!-- Nav + logo right -->
    <div class="footer-content">
      <nav class="footer-nav" aria-label="Footer navigation">
        {navLinks.map((link) => (
          <a href={withBase(link.href)} class="footer-nav-link">{link.label}</a>
        ))}
      </nav>

      <div class="footer-social">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            class="footer-social-link"
            aria-label={link.label}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="footer-bottom">
        <a href={withBase('/')} class="footer-brand" aria-label={siteName}>
          <div class="footer-brand__kanji-grid">
            <span>椿</span>
          </div>
          <div class="footer-brand__mountain" aria-hidden="true"></div>
          <span class="footer-brand__en" aria-hidden="true">Tsubaki</span>
        </a>
        <a href={withBase('/privacy')} class="footer-privacy">Privacy Policy</a>
        <p class="footer-copyright">&copy; {copyrightYear} {siteName}</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-cream-dark);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.45fr) minmax(0, 0.55fr);
    min-height: 28rem;
  }

  /* Photo column. */
  .footer-photo {
    overflow: clip;
  }

  .footer-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Content column. */
  .footer-content {
    display: grid;
    grid-template-rows: auto auto 1fr;
    gap: 1.5rem;
    padding: 3rem clamp(1.5rem, 4vw, 4rem);
    align-content: start;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
  }

  .footer-nav-link {
    font-family: var(--font-sans-jp);
    font-size: var(--text-sm);
    color: var(--color-ink-mid);
    transition: color var(--transition-fast);
  }

  .footer-nav-link:hover {
    color: var(--color-ink);
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }

  .footer-social-link {
    font-family: var(--font-sans-jp);
    font-size: var(--text-sm);
    color: var(--color-ink-mid);
    transition: color var(--transition-fast);
  }

  .footer-social-link:hover {
    color: var(--color-ink);
  }

  .footer-bottom {
    display: grid;
    gap: 0.8rem;
    align-content: end;
  }

  .footer-brand {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    color: var(--color-ink);
  }

  .footer-brand__kanji-grid {
    display: flex;
    gap: 0.25em;
    font-family: var(--font-serif-jp);
    font-size: clamp(0.85rem, 1.4vw, 1.1rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: 0.04em;
  }

  .footer-brand__kanji-grid span {
    display: block;
  }

  .footer-brand__mountain {
    width: 2.4rem;
    height: 0.85rem;
    background: var(--color-gold);
    clip-path: polygon(12% 100%, 50% 0%, 88% 100%);
    margin-top: auto;
    margin-bottom: 2px;
    align-self: flex-end;
  }

  .footer-brand__en {
    font-family: var(--font-sans-jp);
    font-size: 0.55rem;
    color: var(--color-ink-light);
    letter-spacing: 0.06em;
    line-height: 1.5;
    writing-mode: vertical-rl;
    align-self: flex-start;
  }

  .footer-privacy {
    font-size: var(--text-xs);
    color: var(--color-ink-light);
    transition: color var(--transition-fast);
  }

  .footer-privacy:hover {
    color: var(--color-ink);
  }

  .footer-copyright {
    font-size: var(--text-xs);
    color: var(--color-ink-light);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }

    .footer-photo img {
      aspect-ratio: 2;
    }

    .footer-content {
      padding: 2rem var(--layout-padding-sm);
    }
  }
</style>
