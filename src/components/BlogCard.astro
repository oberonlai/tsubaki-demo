---
/**
 * Blog post card — 16:9 featured image, category, date, title, excerpt,
 * and "Read more" view-more pattern.
 */
interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  heroImage?: string;
  tags?: string[];
}

const { href, title, description, date, heroImage, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

function withBase(path: string): string {
  if (/^(?:[a-z]+:)?\/\//i.test(path)) return path;
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return path === '/' ? `${base}/` : `${base}/${path.replace(/^\//, '')}`;
}
---

<article class="blog-card" data-reveal>
  <a href={withBase(href)} class="blog-card__image-link" tabindex="-1" aria-hidden="true">
    <div class="blog-card__image-wrap">
      {heroImage ? (
        <img
          src={withBase(heroImage)}
          alt={title}
          class="blog-card__image"
          loading="lazy"
          decoding="async"
          width="720"
          height="405"
        />
      ) : (
        <div class="blog-card__image-placeholder" aria-hidden="true"></div>
      )}
    </div>
  </a>

  <div class="blog-card__body">
    <div class="blog-card__meta">
      {tags.length > 0 && (
        <span class="blog-card__tag">{tags[0]}</span>
      )}
      <time class="blog-card__date" datetime={date.toISOString()}>{formattedDate}</time>
    </div>

    <h2 class="blog-card__title">
      <a href={withBase(href)}>{title}</a>
    </h2>

    <p class="blog-card__excerpt">{description}</p>

    <a href={withBase(href)} class="view-more-link" aria-label={`Read more — ${title}`}>
      <span class="link-text">Read more</span>
      <span class="arrow-circle" aria-hidden="true">→</span>
    </a>
  </div>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    background-color: transparent;
    border: var(--border-default);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: box-shadow var(--transition-base);
  }

  .blog-card:hover {
    box-shadow: 0 4px 16px rgba(42, 42, 42, 0.08);
  }

  /* Image */
  .blog-card__image-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .blog-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .blog-card:hover .blog-card__image {
    transform: scale(1.03);
  }

  .blog-card__image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-border) 0%, var(--color-bg-input) 100%);
  }

  /* Body */
  .blog-card__body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  /* Meta row */
  .blog-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .blog-card__tag {
    font-size: var(--text-caption);
    letter-spacing: var(--ls-tight);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
  }

  .blog-card__date {
    font-size: var(--text-caption);
    letter-spacing: var(--ls-tight);
    color: var(--color-text-secondary);
  }

  /* Title */
  .blog-card__title {
    font-size: var(--text-h3);
    font-weight: 500;
    line-height: var(--lh-heading);
    letter-spacing: var(--ls-base);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__title a {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .blog-card__title a:hover {
    color: var(--color-accent-dark);
  }

  /* Excerpt */
  .blog-card__excerpt {
    font-size: var(--text-body);
    line-height: var(--lh-body);
    color: var(--color-text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
</style>
