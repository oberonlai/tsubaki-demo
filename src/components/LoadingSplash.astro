---
/**
 * Loading splash screen — full-screen overlay shown on first visit.
 * Skipped on repeat visits via sessionStorage flag.
 * Uses GSAP for a cinematic entrance/exit sequence.
 * Logo: 椿 kanji as brand mark with Tsubaki English label.
 */
---

<div id="loading-splash" class="loading-splash" aria-hidden="true" role="status">
  <div class="loading-splash__inner">
    <div class="loading-splash__logo" aria-label="Tsubaki">
      <div class="loading-splash__kanji-block">
        <span class="loading-splash__kanji-col">
          <span>椿</span>
        </span>
      </div>
      <span class="loading-splash__en" aria-hidden="true">Tsubaki</span>
    </div>
    <div class="loading-splash__mountain" aria-hidden="true"></div>
  </div>
</div>

<style>
  .loading-splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--color-cream);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .loading-splash__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    opacity: 0;
    transform: translateY(1rem);
  }

  .loading-splash__logo {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .loading-splash__kanji-block {
    display: flex;
    gap: 0.15em;
  }

  .loading-splash__kanji-col {
    display: flex;
    flex-direction: column;
    gap: 0.05em;
    font-family: var(--font-serif-jp);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-ink);
    letter-spacing: 0.02em;
  }

  .loading-splash__kanji-col--ri {
    font-size: clamp(1.6rem, 5vw, 2.8rem);
    padding-top: 0.1em;
  }

  .loading-splash__en {
    font-family: var(--font-sans-jp);
    font-size: clamp(0.6rem, 1.2vw, 0.75rem);
    color: var(--color-ink-light);
    letter-spacing: 0.08em;
    line-height: 1.6;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    padding-top: 0.2em;
    align-self: flex-start;
  }

  .loading-splash__mountain {
    width: clamp(6rem, 14vw, 10rem);
    height: clamp(2.5rem, 5vw, 4rem);
    background: var(--color-gold);
    clip-path: polygon(15% 100%, 50% 0%, 85% 100%);
    margin-top: -0.5rem;
    align-self: flex-start;
    margin-left: clamp(1.5rem, 4vw, 3rem);
  }
</style>

<script>
  async function initSplash() {
    const splash = document.getElementById('loading-splash');
    if (!splash) return;

    const seen = sessionStorage.getItem('tsubaki-splash-seen');
    if (seen) {
      splash.style.display = 'none';
      return;
    }

    /* GSAP-driven cinematic entrance. */
    try {
      const { gsap } = await import('gsap');
      const inner = splash.querySelector('.loading-splash__inner') as HTMLElement;

      const tl = gsap.timeline({
        onComplete: () => {
          sessionStorage.setItem('tsubaki-splash-seen', '1');
        },
      });

      tl.to(inner, { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' })
        .to(inner, { opacity: 0, y: -16, duration: 0.55, ease: 'power2.in' }, '+=0.6')
        .to(splash, { opacity: 0, duration: 0.45, ease: 'power2.inOut', onComplete: () => {
          splash.style.display = 'none';
        } }, '-=0.2');
    } catch {
      /* Fallback: simple fade if GSAP fails. */
      const inner = splash.querySelector('.loading-splash__inner') as HTMLElement | null;
      if (inner) {
        inner.style.opacity = '1';
        inner.style.transform = 'none';
      }
      splash.style.transition = 'opacity 0.45s ease';
      setTimeout(() => {
        splash.style.opacity = '0';
        splash.addEventListener('transitionend', () => {
          splash.style.display = 'none';
          sessionStorage.setItem('tsubaki-splash-seen', '1');
        }, { once: true });
      }, 1400);
    }
  }

  initSplash();
</script>
