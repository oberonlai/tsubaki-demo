---
import ThemeToggle from './ThemeToggle.astro';
import { withBase } from '@utils/base-path';

const navLinks = [
  { href: withBase('/'), label: 'Home' },
  { href: withBase('/blog'), label: 'Blog' },
  { href: withBase('/search'), label: 'Search' },
  { href: withBase('/about'), label: 'About' },
  { href: withBase('/tags'), label: 'Tags' },
];

const base = withBase('/');
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const normalizedBase = base.replace(/\/+$/, '') || '/';

function isActive(href: string): boolean {
  const target = href.replace(/\/+$/, '') || '/';
  if (target === normalizedBase) {
    return currentPath === target;
  }

  return currentPath === target || currentPath.startsWith(`${target}/`);
}
---

<nav class="nav" aria-label="Main navigation">
  <div class="container nav__inner">
    <a href={base} class="nav__logo" aria-label="Tsubaki — Home">
      <span class="nav__logo-kanji" aria-hidden="true">椿</span>
      <span class="nav__logo-copy">
        <span class="nav__logo-name">Tsubaki</span>
        <span class="nav__logo-note">Ceremonial editorial theme</span>
      </span>
    </a>

    <ul class="nav__links" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="nav__link"
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="nav__right">
      <ThemeToggle />
      <button
        class="nav__hamburger"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="hamburger-btn"
      >
        <span class="nav__hamburger-line"></span>
        <span class="nav__hamburger-line"></span>
        <span class="nav__hamburger-line"></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu" class="nav__mobile" role="dialog" aria-label="Mobile navigation" aria-modal="true">
  <ul role="list">
    {navLinks.map(({ href, label }) => (
      <li>
        <a href={href} class="nav__mobile-link">{label}</a>
      </li>
    ))}
  </ul>
</div>

<script>
  function initNav(): void {
    const btn = document.getElementById('hamburger-btn');
    const menu = document.getElementById('mobile-menu');

    if (btn === null || menu === null) {
      return;
    }

    btn.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(isOpen));
    });

    // Close on link click.
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  document.addEventListener('astro:page-load', initNav);
</script>
