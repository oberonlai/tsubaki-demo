---
import BaseLayout from './BaseLayout.astro';
import TagCloud from '../components/TagCloud.astro';

interface Props {
  title: string;
  titleEn?: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
}

const {
  title,
  description,
  date,
  updatedDate,
  heroImage,
  tags = [],
} = Astro.props;

function formatDate(d: Date): string {
  return `${d.getFullYear()}.${d.getMonth() + 1}.${d.getDate()}`;
}

const formattedDate = formatDate(date);
const formattedUpdatedDate = updatedDate ? formatDate(updatedDate) : null;

function withBase(path: string): string {
  if (/^(?:[a-z]+:)?\/\//i.test(path)) return path;
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return path === '/' ? `${base}/` : `${base}/${path.replace(/^\//, '')}`;
}

const tagList = tags.map((name) => ({ name, count: 0 }));
---

<BaseLayout title={title} description={description}>
  <article class="post-article">

    <!-- ARTICLE HEADER: matches news-article reference screenshot -->
    <section class="section post-header-section">
      <div class="container">
        <div class="post-header" data-reveal>
          <span class="section-overline">お知らせ</span>
          <h1 class="post-page-label">News</h1>
          <hr class="post-header__rule" aria-hidden="true" />
          <time class="post-header__date" datetime={date.toISOString()}>{formattedDate}</time>
          {formattedUpdatedDate && <span class="post-header__updated">Updated {formattedUpdatedDate}</span>}
          <h2 class="post-title">{title}</h2>

          {tags.length > 0 && (
            <div class="post-header__tags">
              {tags.map((tag) => (
                <span class="post-tag">[ {tag} ]</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- ARTICLE BODY -->
    <section class="section post-body-section">
      <div class="container">
        {heroImage && (
          <figure class="post-hero" data-reveal>
            <img
              src={withBase(heroImage)}
              alt={title}
              class="post-hero__img"
              width="1440"
              height="900"
              loading="eager"
              decoding="async"
            />
          </figure>
        )}

        <div class="post-body" data-reveal>
          <slot />
        </div>
      </div>
    </section>

    <!-- BACK TO LIST -->
    <section class="section post-footer-section">
      <div class="container">
        <hr class="post-footer__rule" aria-hidden="true" />
        <a href={withBase('/news')} class="back-link">← 一覧に戻る</a>
        <hr class="post-footer__rule" aria-hidden="true" />
      </div>
    </section>

    {tags.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="post-tags-footer" data-reveal>
            <TagCloud tags={tagList} />
          </div>
        </div>
      </section>
    )}

  </article>
</BaseLayout>

<style>
  .post-header-section {
    padding-bottom: 0;
  }

  .post-header {
    display: grid;
    gap: 0.8rem;
    max-width: 44rem;
  }

  .post-page-label {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: 400;
    line-height: 0.95;
    color: var(--color-ink);
  }

  .post-header__rule {
    width: 3.5rem;
    height: 1px;
    background: var(--color-rule);
    border: none;
    margin: 0.5rem 0;
  }

  .post-header__date {
    font-size: var(--text-sm);
    color: var(--color-ink-light);
    letter-spacing: 0.04em;
  }

  .post-header__updated {
    font-size: var(--text-xs);
    color: var(--color-ink-light);
  }

  .post-title {
    font-family: var(--font-serif-jp);
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 700;
    line-height: 1.5;
    color: var(--color-ink);
    max-width: 680px;
  }

  .post-header__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-tag {
    font-size: var(--text-xs);
    color: var(--color-ink-mid);
    letter-spacing: 0.04em;
  }

  .post-hero {
    margin-bottom: var(--space-xl);
    overflow: clip;
  }

  .post-hero__img {
    width: 100%;
    aspect-ratio: 1.6;
    object-fit: cover;
  }

  .post-body {
    max-width: 680px;
    font-family: var(--font-sans-jp);
    font-size: var(--text-body-lg);
    line-height: 2;
    color: var(--color-ink);
  }

  .post-body :global(h2) {
    font-size: var(--text-h2);
    font-family: var(--font-serif-jp);
    font-weight: 600;
    line-height: 1.3;
    margin: 3rem 0 1rem;
  }

  .post-body :global(h3) {
    font-size: var(--text-h3);
    font-weight: 600;
    margin: 2.25rem 0 0.9rem;
  }

  .post-body :global(p) {
    margin-bottom: 1.3rem;
  }

  .post-body :global(img) {
    width: 100%;
    margin-block: 2rem;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 1.25rem 0 1.6rem 1.3rem;
    padding-left: 1rem;
  }

  .post-body :global(ul) {
    list-style: disc;
  }

  .post-body :global(ol) {
    list-style: decimal;
  }

  .post-body :global(li) {
    margin-bottom: 0.55rem;
  }

  .post-body :global(a) {
    color: var(--color-gold-deep);
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }

  .post-footer-section {
    padding-top: 0;
  }

  .post-footer__rule {
    width: 100%;
    height: 1px;
    background: var(--color-rule);
    border: none;
    margin: 0;
  }

  .back-link {
    display: inline-block;
    padding: 1.2rem 0;
    font-size: var(--text-sm);
    color: var(--color-ink-mid);
    letter-spacing: 0.04em;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-gold);
  }

  .post-tags-footer {
    padding-block: var(--space-lg);
  }
</style>
