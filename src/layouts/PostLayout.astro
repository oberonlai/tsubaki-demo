---
/**
 * Article layout — single column, max-width 720px, no sidebar.
 */
import BaseLayout from './BaseLayout.astro';
import TagCloud from '../components/TagCloud.astro';

interface Props {
  title: string;
  titleEn?: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
}

const {
  title,
  titleEn,
  description,
  date,
  updatedDate,
  heroImage,
  tags = [],
} = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
const formattedUpdatedDate = updatedDate
  ? updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })
  : null;

function withBase(path: string): string {
  if (/^(?:[a-z]+:)?\/\//i.test(path)) return path;
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return path === '/' ? `${base}/` : `${base}/${path.replace(/^\//, '')}`;
}

const tagList = tags.map((name) => ({ name, count: 0 }));
---

<BaseLayout title={title} description={description}>
  <article class="post-article">
    <div class="container">

      <!-- Article header -->
      <header class="post-header">
        {tags.length > 0 && (
          <div class="post-header__tags">
            {tags.map((tag) => (
              <a href={withBase(`/tags/${tag}`)} class="post-tag">{tag}</a>
            ))}
          </div>
        )}

        <h1 class="post-title">
          <span class="post-title__ja">{title}</span>
          {titleEn && <span class="post-title__en">{titleEn}</span>}
        </h1>

        <div class="post-meta">
          <time class="post-meta__date" datetime={date.toISOString()}>
            {formattedDate}
          </time>
          {formattedUpdatedDate && (
            <span class="post-meta__updated">Updated {formattedUpdatedDate}</span>
          )}
        </div>
      </header>

      <!-- Hero image -->
      {heroImage && (
        <div class="post-hero">
          <img
            src={withBase(heroImage)}
            alt={title}
            class="post-hero__img"
            width="1440"
            height="810"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      <!-- Article prose -->
      <div class="post-body">
        <slot />
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <footer class="post-footer">
          <div class="post-footer__tags">
            <h2 class="section-heading">
              <span class="heading-ja">Tags</span>
              <span class="heading-en">Tags</span>
            </h2>
            <TagCloud tags={tagList} />
          </div>
        </footer>
      )}

    </div>
  </article>
</BaseLayout>

<style>
  .post-article {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  /* Header */
  .post-header {
    max-width: var(--layout-article-width);
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }

  .post-header__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .post-tag {
    font-size: var(--text-caption);
    letter-spacing: var(--ls-tight);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    padding: 2px 10px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .post-tag:hover {
    background-color: var(--color-accent);
    color: var(--color-bg-surface);
    border-color: var(--color-accent);
  }

  .post-title {
    margin-bottom: var(--space-4);
  }

  .post-title__ja {
    display: block;
    font-size: var(--text-h1);
    font-weight: 500;
    line-height: var(--lh-heading);
    letter-spacing: var(--ls-base);
    color: var(--color-text-primary);
  }

  .post-title__en {
    display: block;
    font-size: var(--text-subtitle-en);
    font-weight: 400;
    letter-spacing: var(--ls-wide);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    margin-top: var(--space-2);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .post-meta__date,
  .post-meta__updated {
    font-size: var(--text-caption);
    letter-spacing: var(--ls-tight);
    color: var(--color-text-secondary);
  }

  /* Hero */
  .post-hero {
    max-width: var(--layout-article-width);
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }

  .post-hero__img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }

  /* Body prose */
  .post-body {
    max-width: var(--layout-article-width);
    margin-inline: auto;
    font-size: var(--text-body);
    line-height: var(--lh-body);
    letter-spacing: var(--ls-base);
    color: var(--color-text-primary);
  }

  .post-body :global(h2) {
    font-size: var(--text-h2);
    font-weight: 500;
    letter-spacing: var(--ls-base);
    margin-top: var(--space-10);
    margin-bottom: var(--space-5);
  }

  .post-body :global(h3) {
    font-size: var(--text-h3);
    font-weight: 500;
    letter-spacing: var(--ls-base);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .post-body :global(p) {
    margin-bottom: var(--space-5);
  }

  .post-body :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    margin-block: var(--space-6);
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-5);
    margin-inline: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-feature);
    line-height: var(--lh-feature);
    letter-spacing: var(--ls-feature);
  }

  .post-body :global(a) {
    color: var(--color-accent-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition-fast);
  }

  .post-body :global(a:hover) {
    color: var(--color-text-primary);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: var(--space-5);
    margin-bottom: var(--space-5);
  }

  .post-body :global(ul) {
    list-style: disc;
  }

  .post-body :global(ol) {
    list-style: decimal;
  }

  .post-body :global(li) {
    margin-bottom: var(--space-2);
  }

  .post-body :global(code) {
    font-family: monospace;
    font-size: 0.875em;
    background-color: var(--color-bg-input);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  .post-body :global(pre) {
    background-color: var(--color-text-primary);
    color: var(--color-bg-primary);
    padding: var(--space-5);
    border-radius: var(--radius-sm);
    overflow-x: auto;
    margin-block: var(--space-6);
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: var(--text-body);
  }

  /* Footer */
  .post-footer {
    max-width: var(--layout-article-width);
    margin-inline: auto;
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: var(--border-default);
  }

  .post-footer__tags {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .post-footer .section-heading {
    margin-bottom: var(--space-4);
  }
</style>
