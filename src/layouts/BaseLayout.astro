---
import '../styles/base.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import LeftSidebar from '../components/LeftSidebar.astro';
import RightSidebar from '../components/RightSidebar.astro';
import {
  siteName as defaultSiteName,
  siteNameEn,
  navLinks as defaultNavLinks,
  footerNavLinks,
  socialLinks,
  latestNewsDate,
  latestNewsTitle,
} from '../data/site';

interface Props {
  title: string;
  description?: string;
  siteName?: string;
  ogImage?: string;
}

const {
  title,
  description = '',
  siteName = defaultSiteName,
  ogImage = '',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const currentDate = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'numeric',
  day: 'numeric',
  weekday: 'short',
}).replace(/\//g, '.');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <title>{title.includes(siteNameEn) || title.includes(siteName) ? title : `${title} — ${siteNameEn}`}</title>
    {description && <meta name="description" content={description} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;600;700&family=Noto+Sans+JP:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <LeftSidebar
      currentDate={currentDate}
      latestNewsDate={latestNewsDate}
      latestNewsTitle={latestNewsTitle}
    />
    <RightSidebar socialLinks={socialLinks} />
    <Navigation siteName={siteName} links={defaultNavLinks} />

    <div class="site-wrapper">
      <main>
        <slot />
      </main>
      <Footer
        siteName={siteName}
        navLinks={footerNavLinks}
        socialLinks={socialLinks}
        copyrightYear={new Date().getFullYear()}
      />
    </div>

    <script>
      function initScrollReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.16 },
        );

        document.querySelectorAll('[data-reveal]').forEach((el, i) => {
          el.style.transitionDelay = `${(i % 5) * 0.08}s`;
          observer.observe(el);
        });
      }

      document.addEventListener('astro:page-load', initScrollReveal);
      document.addEventListener('astro:after-swap', initScrollReveal);
      initScrollReveal();
    </script>
  </body>
</html>
