{
  "name": "tsubaki-astro-theme",
  "version": "1.0.0",
  "description": "Tsubaki (椿) — Japanese-inspired blog theme for Astro with GSAP animations",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "pnpm run build && wrangler dev",
    "lint": "eslint src --ext .js,.ts,.astro",
    "format": "prettier --write \"**/*.{js,ts,astro,css,json,md,mdx}\"",
    "generate-types": "wrangler types",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.2",
    "@astrojs/mdx": "^5.0.1",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "astro": "^6.0.5",
    "gsap": "^3.14.2"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "wrangler": "^4.75.0"
  },
  "keywords": [
    "astro-component",
    "withastro",
    "blog",
    "theme",
    "japanese",
    "gsap",
    "animation",
    "minimal",
    "dark-mode",
    "tailwind"
  ],
  "homepage": "https://oberonlai.github.io/tsubaki-demo",
  "repository": {
    "type": "git",
    "url": "https://github.com/oberonlai/tsubaki-demo"
  },
  "bugs": {
    "url": "https://github.com/oberonlai/tsubaki-demo/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Codotx <hello@codotx.com> (https://codotx.com)"
}
